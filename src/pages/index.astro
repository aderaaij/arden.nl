---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import GlitchWordmark from "../components/GlitchWordmark";
import WritingRows from "../components/WritingRows.astro";

const posts = (await getCollection("writing")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base>
  <header class="home-header">
    <p class="eyebrow home-eyebrow" data-rise data-rise-delay="0.06">
      Front-end engineer
    </p>
    <h1 class="home-wordmark" data-rise data-rise-delay="0.13">
      <GlitchWordmark client:load />
    </h1>
    <p class="intro" data-rise data-rise-delay="0.21">
      Building things for the web since 2008. Mostly React and TypeScript,
      usually on data-heavy products. Creative roots and a sharp eye for design.
      I care how a thing feels to use as much as how it's built.
    </p>
    <nav class="paths" data-rise data-rise-delay="0.29">
      <a class="path" href="/writing">Writing</a>
      <a class="path" href="/about">About</a>
      {
        /* Hidden until photo.arden.nl is live:
      <a class="path" href="https://photo.arden.nl">Photography</a> */
      }
      <a
        class="path-mono"
        href="https://github.com/aderaaij"
        target="_blank"
        rel="noopener">GitHub ↗</a
      >
      <a
        class="path-mono"
        href="https://linkedin.com/in/ardenderaaij"
        target="_blank"
        rel="noopener">LinkedIn ↗</a
      >
      <a
        class="path-mono"
        href="https://instagram.com/ardennl"
        target="_blank"
        rel="noopener">Instagram ↗</a
      >
    </nav>
  </header>

  <section class="section" data-rise data-rise-delay="0.37">
    <div class="section-label"><span class="mark">§</span>Selected writing</div>
    <WritingRows posts={posts} />
    <a class="more-link" href="/writing">All writing, and the archive →</a>
  </section>
</Base>

<style>
  .home-header {
    padding: clamp(56px, 10vw, 96px) 0 78px;
  }

  .home-eyebrow {
    margin: 0 0 26px;
  }

  .home-wordmark {
    margin: 0;
    line-height: 1;
  }

  .intro {
    margin: 40px 0 0;
    max-width: 52ch;
    font-size: clamp(17px, 2.2vw, 20px);
    line-height: 1.5;
    color: var(--intro);
  }

  .intro b {
    font-weight: 600;
    color: var(--ink);
  }

  .paths {
    margin-top: 44px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px 30px;
    align-items: baseline;
  }

  .path {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 17px;
    text-decoration: none;
    color: var(--ink);
    padding-bottom: 3px;
    box-shadow: inset 0 -2px 0 transparent;
    transition: box-shadow 0.14s;
  }

  .path:hover {
    box-shadow: inset 0 -2px 0 var(--blue);
  }

  .path-mono {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--muted);
    text-decoration: none;
    box-shadow: inset 0 -1.5px 0 transparent;
    transition:
      box-shadow 0.14s,
      color 0.14s;
  }

  .path-mono:hover {
    color: var(--ink);
    box-shadow: inset 0 -1.5px 0 var(--muted);
  }
</style>
